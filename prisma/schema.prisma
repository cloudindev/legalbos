generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id        String     @id @default(uuid())
  name      String
  domain    String?    @unique
  createdAt DateTime   @default(now())
  claudeApiKey String?
  aiEnabled    Boolean    @default(false)

  // Datos fiscales
  fiscalType   String     @default("COMPANY")
  fiscalName   String?
  taxId        String?
  address      String?
  city         String?
  postalCode   String?
  province     String?
  country      String?
  auditLogs AuditLog[]
  caseFiles CaseFile[]
  clients   Client[]
  documents           Document[]
  users               User[]
  contactCategories   ContactCategory[]
  directoryContacts   DirectoryContact[]
  casePhases          CasePhase[]
  caseTypes           CaseType[]
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash String
  name         String
  firstName    String?
  lastName1    String?
  lastName2    String?
  role         Role         @default(LAWYER)
  tenantId     String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  annotations  Annotation[]
  auditLogs    AuditLog[]
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedCases CaseFile[]   @relation("CaseFileUsers")
}

model Client {
  id           String        @id @default(uuid())
  email        String?
  phone        String?
  type         String        @default("INDIVIDUAL")
  nifCif       String?
  tenantId     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  address      String?
  city         String?
  companyName  String?
  country      String?
  firstName    String?
  lastName1    String?
  lastName2    String?
  mobile       String?
  postalCode   String?
  province     String?
  tradeName    String?
  annotations  Annotation[]
  bankAccounts BankAccount[]
  caseFiles    CaseFile[]
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contacts     Contact[]
  interactions Interaction[]
  documents    Document[]
}

model Contact {
  id        String   @id @default(uuid())
  firstName String
  lastName  String?
  email     String?
  phone     String?
  jobTitle  String?
  clientId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model BankAccount {
  id        String  @id @default(uuid())
  iban      String
  swift     String?
  bankName  String?
  isDefault Boolean @default(true)
  clientId  String
  client    Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Annotation {
  id        String   @id @default(uuid())
  content   String
  type      String?
  documentUrl String?
  isPinned  Boolean  @default(false)
  authorId  String
  clientId  String?
  caseFileId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id])
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  caseFile  CaseFile? @relation(fields: [caseFileId], references: [id], onDelete: Cascade)
}

model CaseFile {
  id               String            @id @default(uuid())
  title            String
  reference        String?
  status           String            @default("OPEN")
  description      String?
  
  // Phase & Type
  phaseId          String?
  typeId           String?
  
  // Conflicting parties
  opposingParty    String?
  opposingLawyerId String?

  tenantId         String
  clientId         String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  
  client           Client            @relation(fields: [clientId], references: [id])
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documents        Document[]
  phase            CasePhase?        @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  type             CaseType?         @relation(fields: [typeId], references: [id], onDelete: SetNull)
  opposingLawyer   DirectoryContact? @relation("CaseFilesOpposingLawyer", fields: [opposingLawyerId], references: [id], onDelete: SetNull)
  assignedUsers    User[]            @relation("CaseFileUsers")
  annotations      Annotation[]
}

model Document {
  id         String   @id @default(uuid())
  name       String
  url        String
  size       Int?
  mimetype   String?
  tenantId   String
  caseFileId String?
  clientId   String?
  createdAt  DateTime @default(now())

  caseFile CaseFile? @relation(fields: [caseFileId], references: [id], onDelete: Cascade)
  client   Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Interaction {
  id        String          @id @default(uuid())
  type      InteractionType
  content   String?
  clientId  String
  createdAt DateTime        @default(now())
  client    Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String
  ipAddress String?
  details   Json?
  userId    String?
  tenantId  String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])
}

enum Role {
  SUPER_ADMIN
  FIRM_ADMIN
  LAWYER
  PARALEGAL
  ACCOUNTING
  READ_ONLY
}

enum InteractionType {
  EMAIL
  WHATSAPP
  CALL
  NOTE
}

model ContactCategory {
  id        String             @id @default(uuid())
  name      String
  tenantId  String
  createdAt DateTime           @default(now())
  
  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contacts  DirectoryContact[]

  @@unique([name, tenantId])
}

model DirectoryContact {
  id          String           @id @default(uuid())
  type        String           @default("INDIVIDUAL") // INDIVIDUAL or COMPANY
  firstName   String?
  lastName    String?
  companyName String?
  nifCif      String?
  email       String?
  phone       String?
  mobile      String?
  address     String?
  city        String?
  province    String?
  postalCode  String?
  country     String?
  notes       String?
  
  categoryId  String?
  tenantId    String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  category    ContactCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  opposingCases CaseFile[]     @relation("CaseFilesOpposingLawyer")
}

model CasePhase {
  id        String     @id @default(uuid())
  name      String
  order     Int        @default(0)
  tenantId  String
  createdAt DateTime   @default(now())
  
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  caseFiles CaseFile[]

  @@unique([name, tenantId])
}

model CaseType {
  id        String     @id @default(uuid())
  name      String
  tenantId  String
  createdAt DateTime   @default(now())
  
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  caseFiles CaseFile[]

  @@unique([name, tenantId])
}
